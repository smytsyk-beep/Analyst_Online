    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
